<Window x:Class="GenshinBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Genshin Browser"
        Width="520"
        Height="860"
        MinWidth="320"
        MinHeight="360"
        Background="#0F1116"
        Foreground="#F4F6FB"
        WindowStartupLocation="Manual">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition x:Name="HistoryRowDefinition" Height="100" />
    </Grid.RowDefinitions>

    <Border x:Name="TopToolbarBorder" Grid.Row="0" Background="#171B24" Padding="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock x:Name="ModeTextBlock" FontSize="14" FontWeight="SemiBold" Text="固定模式" />
          <TextBlock x:Name="StatusTextBlock" Margin="0,2,0,0" FontSize="11" Foreground="#9BA7BF" Text="正在初始化浏览器..." />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="ToggleModeButton" MinWidth="56" Margin="0,0,6,0" Padding="8,4" FontSize="11" Click="ToggleModeButton_OnClick">切换模式</Button>
          <Button x:Name="PlayPauseButton" MinWidth="56" Margin="0,0,6,0" Padding="8,4" FontSize="11" Click="PlayPauseButton_OnClick">播放/暂停</Button>
          <Button x:Name="HomeButton" MinWidth="56" Padding="8,4" FontSize="11" Click="HomeButton_OnClick">原神攻略</Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border x:Name="AddressBarBorder" Grid.Row="1" Background="#11151D" Padding="8,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBox x:Name="AddressBarTextBox"
                 Padding="8,4"
                 FontSize="11"
                 BorderThickness="0"
                 Background="#202634"
                 Foreground="#F4F6FB"
                 KeyDown="AddressBarTextBox_OnKeyDown" />

        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
          <Button MinWidth="48" Padding="8,4" Margin="0,0,6,0" FontSize="11" Click="GoButton_OnClick">打开</Button>
          <Button MinWidth="48" Padding="8,4" FontSize="11" Click="ReloadButton_OnClick">刷新</Button>
        </StackPanel>
      </Grid>
    </Border>

    <wv2:WebView2 x:Name="BrowserView" Grid.Row="2" />

    <Border x:Name="HistoryPanelBorder" Grid.Row="3" Background="#171B24" Padding="8,6">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="12" FontWeight="SemiBold" Text="浏览记录" />
        <ListBox x:Name="HistoryListBox"
                 FontSize="11"
                 Background="#11151D"
                 BorderThickness="0"
                 Foreground="#F4F6FB"
                 MouseDoubleClick="HistoryListBox_OnMouseDoubleClick"
                 DisplayMemberPath="DisplayText" />
      </DockPanel>
    </Border>
  </Grid>
</Window>

<Application
    x:Class="GenshinBrowser.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:GenshinBrowser.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
                <ResourceDictionary Source="ms-appx:///Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:DownloadStateTextConverter x:Key="DownloadStateText"/>
            <converters:StatusLevelToInfoBarSeverityConverter x:Key="StatusLevelToInfoBarSeverity"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>

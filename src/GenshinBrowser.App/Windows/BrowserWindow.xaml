<Window
    x:Class="GenshinBrowser.Windows.BrowserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:localization="using:GenshinBrowser.Localization">

    <Grid
        x:Name="BrowserRoot"
        Background="{ThemeResource GbPageBackgroundBrush}"
        PreviewKeyDown="BrowserRoot_OnPreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid
            x:Name="TitleBarArea"
            Grid.Row="0"
            Canvas.ZIndex="10"
            Style="{StaticResource GbWindowTitleBarStyle}"
            PointerEntered="TitleBarDragRegion_OnPointerEntered"
            PointerExited="TitleBarDragRegion_OnPointerExited">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="CaptionButtonInsetColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <Grid
                x:Name="TitleBarDragRegion"
                Grid.Column="0"
                Background="Transparent">
                <TextBlock
                    x:Name="DocumentTitleText"
                    Margin="12,0"
                    Style="{StaticResource GbWindowTitleTextStyle}"
                    Text="Genshin Browser"/>
            </Grid>

            <Button
                Grid.Column="1"
                x:Name="ModeToggleButton"
                Width="46"
                Height="32"
                Style="{StaticResource GbCaptionButtonStyle}"
                Click="ModeToggleButton_Click"
                localization:LocalizationBinding.Key="Mode.ToggleName"
                localization:LocalizationBinding.Target="ToolTip"
                ToolTipService.ToolTip="切换浏览与浮窗">
                <FontIcon x:Name="ModeToggleIcon" Glyph="&#xE718;" FontSize="12"/>
            </Button>

            <Button
                Grid.Column="2"
                Width="46"
                Height="32"
                Style="{StaticResource GbCaptionButtonStyle}"
                Click="MinimizeButton_Click"
                localization:LocalizationBinding.Key="TitleBar.Minimize"
                localization:LocalizationBinding.Target="ToolTip"
                ToolTipService.ToolTip="最小化">
                <FontIcon Glyph="&#xE921;" FontSize="11"/>
            </Button>

            <Button
                x:Name="MaximizeButton"
                Grid.Column="3"
                Width="46"
                Height="32"
                Style="{StaticResource GbCaptionButtonStyle}"
                Click="MaximizeButton_Click"
                localization:LocalizationBinding.Key="TitleBar.Maximize"
                localization:LocalizationBinding.Target="ToolTip"
                ToolTipService.ToolTip="最大化">
                <FontIcon x:Name="MaximizeIcon" Glyph="&#xE922;" FontSize="11"/>
            </Button>

            <Button
                Grid.Column="4"
                Width="48"
                Height="32"
                Style="{StaticResource GbCaptionCloseButtonStyle}"
                Click="CloseButton_Click"
                localization:LocalizationBinding.Key="TitleBar.Close"
                localization:LocalizationBinding.Target="ToolTip"
                ToolTipService.ToolTip="关闭">
                <FontIcon Glyph="&#xE8BB;" FontSize="11"/>
            </Button>
        </Grid>

        <Grid
            x:Name="BrowserSurface"
            Grid.Row="1"
            Background="{ThemeResource GbWebViewBackgroundBrush}">
            <WebView2
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                localization:LocalizationBinding.Key="Browser.ContentName"
                localization:LocalizationBinding.Target="AutomationName"
                DefaultBackgroundColor="#FF101010"/>
        </Grid>

        <Border
            x:Name="TitleBarRevealStrip"
            Grid.RowSpan="2"
            Canvas.ZIndex="20"
            Height="6"
            VerticalAlignment="Top"
            Background="Transparent"
            PointerEntered="TitleBarRevealStrip_OnPointerEntered"/>

        <Border
            x:Name="ModeToast"
            Grid.RowSpan="2"
            Canvas.ZIndex="30"
            Style="{StaticResource GbModeToastStyle}"
            IsHitTestVisible="False"
            Transitions="{StaticResource GbEntranceTransitions}"
            Visibility="Collapsed">
            <TextBlock
                x:Name="ModeToastText"
                MaxWidth="420"
                TextAlignment="Center"
                TextWrapping="Wrap"
                AutomationProperties.LiveSetting="Polite"/>
        </Border>
    </Grid>
</Window>

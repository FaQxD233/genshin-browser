<Window x:Class="GenshinBrowser.Windows.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:GenshinBrowser.Models"
        xmlns:services="clr-namespace:GenshinBrowser.Services"
        Title="{DynamicResource Control.Title}"
        Width="560"
        Height="640"
        MinWidth="400"
        MinHeight="440"
        Background="{DynamicResource BackgroundPrimary}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="Manual"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow">
  <Window.Resources>
    <services:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

    <DataTemplate x:Key="DownloadItemTemplate" DataType="{x:Type models:DownloadItem}">
      <Grid Margin="0,4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="Medium"
                     TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimary}"
                     ToolTip="{Binding FileName}" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1" Text="{Binding StateText}" FontSize="11"
                     Margin="12,0,0,0" Foreground="{DynamicResource TextTertiary}"
                     VerticalAlignment="Center"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,6,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <ProgressBar Grid.Column="0" Style="{StaticResource ModernProgressBar}"
                       Value="{Binding Progress}" VerticalAlignment="Center" Height="5"/>
          <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="11"
                     Margin="10,0,0,0" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
          <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="24" Margin="8,0,0,0"
                  Command="{Binding DataContext.OpenDownloadFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="{DynamicResource Downloads.OpenFile}"
                  IsEnabled="{Binding CanOpen}"
                  AutomationProperties.Name="{DynamicResource Downloads.OpenFile}">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE7B3;" FontSize="12"/>
          </Button>
          <Button Grid.Column="3" Style="{StaticResource IconButton}" Width="28" Height="24" Margin="4,0,0,0"
                  Command="{Binding DataContext.OpenDownloadFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="{DynamicResource Downloads.OpenFolder}"
                  IsEnabled="{Binding CanOpenInFolder}"
                  AutomationProperties.Name="{DynamicResource Downloads.OpenFolder}">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE8DA;" FontSize="12"/>
          </Button>
          <Button Grid.Column="4" Style="{StaticResource IconButton}" Width="28" Height="24" Margin="4,0,0,0"
                  Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="{DynamicResource Downloads.Cancel}"
                  IsEnabled="{Binding CanCancel}"
                  AutomationProperties.Name="{DynamicResource Downloads.Cancel}">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE711;" FontSize="12"/>
          </Button>
        </Grid>
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Grid Margin="16,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid.Triggers>
      <EventTrigger RoutedEvent="FrameworkElement.Loaded">
        <BeginStoryboard>
          <Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </Grid.Triggers>

    <!-- Row 0: 顶栏 — 扁平；与下方区块间距 12 -->
    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,10,0" VerticalAlignment="Center">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ModeToggleIcon}" Value="&#xE785;">
                  <Setter Property="Background" Value="#F0A020"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
        </Border>
        <TextBlock Style="{StaticResource Mdl2IconText}" Text="{Binding ModeToggleIcon}"
                   Margin="0,0,8,0" FontSize="15" Foreground="{DynamicResource TextSecondary}"/>
        <TextBlock FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}"
                   Text="{Binding ModeText}"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- 四个工具按钮：统一 34x30、间距 6、图标居中 -->
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Button Style="{StaticResource IconButton}" Width="34" Height="30" Margin="0,0,6,0" Padding="0"
                Command="{Binding ToggleModeCommand}" ToolTip="{DynamicResource Mode.ToggleTooltip}"
                AutomationProperties.Name="{DynamicResource Mode.ToggleName}">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="{Binding ModeToggleIcon}" FontSize="13"/>
        </Button>
        <Button Style="{StaticResource IconButton}" Width="34" Height="30" Margin="0,0,6,0" Padding="0"
                Command="{Binding TogglePlaybackCommand}" ToolTip="{DynamicResource Toolbar.PlaybackTooltip}"
                AutomationProperties.Name="{DynamicResource Toolbar.PlaybackName}">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE769;" FontSize="13"/>
        </Button>
        <Button x:Name="SettingsButton" Width="34" Height="30" Margin="0,0,6,0" Padding="0"
                Command="{Binding ToggleSettingsCommand}"
                ToolTip="{DynamicResource Toolbar.SettingsTooltip}" AutomationProperties.Name="{DynamicResource Toolbar.SettingsName}">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
              <Setter Property="Padding" Value="0"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsSettingsExpanded}" Value="True">
                  <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE713;" FontSize="13"/>
        </Button>
        <!-- 下载：固定尺寸，图标居中；角标叠在右上角，避免把图标挤歪 -->
        <Button x:Name="DownloadsButton" Width="34" Height="30" Padding="0"
                Command="{Binding ToggleDownloadsCommand}"
                ToolTip="{DynamicResource Toolbar.DownloadsTooltip}" AutomationProperties.Name="{DynamicResource Toolbar.DownloadsName}">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
              <Setter Property="Padding" Value="0"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsDownloadsExpanded}" Value="True">
                  <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <Grid Width="18" Height="18">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE896;" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DownloadsBadgeText}" FontSize="9" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimary}"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,-4,-6,0"/>
          </Grid>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Row 1: 设置面板
         外层透明壳只负责 MaxHeight 动画（折叠=0，不占位）；
         内层才是可见底色，Margin 底 12 在壳内，折叠时一并被裁掉 -->
    <Border Grid.Row="1" x:Name="SettingsPanelBorder"
            Background="Transparent"
            Margin="0" Padding="0"
            ClipToBounds="True" MaxHeight="0" Opacity="0">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsSettingsExpanded}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight" To="420" Duration="0:0:0.2"
                                     EasingFunction="{StaticResource EaseOutCubic}"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.14"/>
                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight" To="0" Duration="0:0:0.16"
                                     EasingFunction="{StaticResource EaseOutCubic}"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.ExitActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <Border Background="{DynamicResource BackgroundSecondary}"
              CornerRadius="6"
              Padding="12"
              Margin="0,0,0,12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="{DynamicResource Settings.Title}" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>
          <StackPanel Grid.Row="1">
            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Opacity}" Foreground="{DynamicResource TextSecondary}"
                         FontSize="12" VerticalAlignment="Center"/>
              <Slider Grid.Column="1" Value="{Binding WindowOpacity, Mode=TwoWay}"
                      Minimum="0.1" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                      VerticalAlignment="Center" Margin="8,0"/>
              <TextBlock Grid.Column="2" Text="{Binding OpacityPercentageText}"
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="Medium"/>
            </Grid>

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Zoom}" Foreground="{DynamicResource TextSecondary}"
                         FontSize="12" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Style="{StaticResource ModernButton}" Width="30" Height="28" MinWidth="0" Padding="0"
                      Command="{Binding ZoomOutCommand}" ToolTip="{DynamicResource Settings.ZoomOutTooltip}" AutomationProperties.Name="{DynamicResource Settings.ZoomOutName}">
                <TextBlock Text="−" FontSize="15" Foreground="{DynamicResource TextPrimary}"/>
              </Button>
              <TextBlock Grid.Column="2" Text="{Binding ZoomPercentageText}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="Medium"/>
              <Button Grid.Column="3" Style="{StaticResource ModernButton}" Width="30" Height="28" MinWidth="0" Padding="0" Margin="4,0,0,0"
                      Command="{Binding ZoomInCommand}" ToolTip="{DynamicResource Settings.ZoomInTooltip}" AutomationProperties.Name="{DynamicResource Settings.ZoomInName}">
                <TextBlock Text="+" FontSize="15" Foreground="{DynamicResource TextPrimary}"/>
              </Button>
              <Button Grid.Column="4" Style="{StaticResource ModernButton}" Padding="10,5" Margin="8,0,0,0"
                      Command="{Binding ResetZoomCommand}" ToolTip="{DynamicResource Settings.ZoomResetTooltip}" FontSize="11" Content="{DynamicResource Settings.ZoomReset}"/>
            </Grid>

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{DynamicResource Settings.ToggleMode}" Foreground="{DynamicResource TextSecondary}"
                         FontSize="12" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Content="{Binding ToggleModeKeyText}"
                      Command="{Binding RecordToggleModeKeyCommand}"
                      Style="{StaticResource ModernButton}" HorizontalContentAlignment="Center"
                      Padding="8,6" FontSize="11"/>
              <TextBlock Grid.Column="3" Text="{DynamicResource Settings.Playback}" Foreground="{DynamicResource TextSecondary}"
                         FontSize="12" VerticalAlignment="Center"/>
              <Button Grid.Column="4" Content="{Binding TogglePlaybackKeyText}"
                      Command="{Binding RecordTogglePlaybackKeyCommand}"
                      Style="{StaticResource ModernButton}" HorizontalContentAlignment="Center"
                      Padding="8,6" FontSize="11"/>
            </Grid>

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Theme}" Foreground="{DynamicResource TextSecondary}"
                         FontSize="12" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                <Button MinWidth="64" Padding="12,6" Margin="0,0,8,0"
                        Command="{Binding SetThemeDarkCommand}"
                        Content="{DynamicResource Settings.ThemeDark}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsThemeDark}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                          <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <Button MinWidth="64" Padding="12,6"
                        Command="{Binding SetThemeLightCommand}"
                        Content="{DynamicResource Settings.ThemeLight}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsThemeLight}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                          <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Language}" Foreground="{DynamicResource TextSecondary}"
                         FontSize="12" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                <Button MinWidth="64" Padding="12,6" Margin="0,0,8,0"
                        Command="{Binding SetLanguageZhCommand}"
                        Content="{DynamicResource Settings.LanguageZh}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLanguageZh}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                          <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <Button MinWidth="64" Padding="12,6"
                        Command="{Binding SetLanguageEnCommand}"
                        Content="{DynamicResource Settings.LanguageEn}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLanguageEn}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                          <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </Grid>

                        <Button Style="{StaticResource ModernButton}" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Padding="10,7"
                    Command="{Binding RestoreDefaultSettingsCommand}"
                    ToolTip="{DynamicResource Settings.RestoreDefaultsTooltip}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72C;" Margin="0,0,8,0" FontSize="13"/>
                <TextBlock Text="{DynamicResource Settings.RestoreDefaults}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </Border>

    <!-- Row 2: 下载面板 — 与设置同一双层结构 -->
    <Border Grid.Row="2" x:Name="DownloadsPanelBorder"
            Background="Transparent"
            Margin="0" Padding="0"
            ClipToBounds="True" MaxHeight="0" Opacity="0">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsDownloadsExpanded}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight" To="260" Duration="0:0:0.2"
                                     EasingFunction="{StaticResource EaseOutCubic}"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.14"/>
                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight" To="0" Duration="0:0:0.16"
                                     EasingFunction="{StaticResource EaseOutCubic}"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.ExitActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <Border Background="{DynamicResource BackgroundSecondary}"
              CornerRadius="6"
              Padding="12"
              Margin="0,0,0,12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource Downloads.Title}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
              <TextBlock Margin="8,0,0,0" FontSize="12"
                         Foreground="{DynamicResource TextTertiary}"
                         Text="{Binding DownloadsEmptyText}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Padding="10,5" FontSize="11"
                    Command="{Binding ClearFinishedDownloadsCommand}"
                    ToolTip="{DynamicResource Downloads.ClearFinishedTooltip}"
                    Content="{DynamicResource Downloads.ClearFinished}"/>
          </Grid>
          <ListBox Grid.Row="1" x:Name="DownloadsListBox"
                   Style="{StaticResource ModernListBox}"
                   MinHeight="72" MaxHeight="168"
                   ItemsSource="{Binding Downloads}"
                   ItemTemplate="{StaticResource DownloadItemTemplate}"
                   Background="Transparent"
                   BorderThickness="0">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem" BasedOn="{StaticResource ModernListBoxItem}">
                <Setter Property="Padding" Value="8,6"/>
              </Style>
            </ListBox.ItemContainerStyle>
          </ListBox>
        </Grid>
      </Border>
    </Border>

    <!-- Row 3: 地址栏 -->
    <Grid Grid.Row="3" Margin="0,0,0,12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
          <Button Style="{StaticResource IconButton}" Width="34" Height="32" Margin="0,0,6,0"
                  Command="{Binding GoBackCommand}"
                  IsEnabled="{Binding CanGoBack}"
                  ToolTip="{DynamicResource Nav.Back}" AutomationProperties.Name="{DynamicResource Nav.Back}">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72B;" FontSize="13"/>
          </Button>
          <Button Style="{StaticResource IconButton}" Width="34" Height="32"
                  Command="{Binding GoForwardCommand}"
                  IsEnabled="{Binding CanGoForward}"
                  ToolTip="{DynamicResource Nav.Forward}" AutomationProperties.Name="{DynamicResource Nav.Forward}">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72A;" FontSize="13"/>
          </Button>
        </StackPanel>

        <TextBox x:Name="AddressBarTextBox"
                 Grid.Column="1"
                 Height="32"
                 VerticalContentAlignment="Center"
                 Style="{StaticResource ModernTextBox}"
                 services:Placeholder.Text="{DynamicResource Nav.AddressPlaceholder}"
                 services:Placeholder.Foreground="{DynamicResource TextTertiary}"
                 ToolTip="{DynamicResource Nav.AddressTooltip}">
          <TextBox.InputBindings>
            <KeyBinding Key="Enter"
                        Command="{Binding NavigateFromAddressBarCommand}"
                        CommandParameter="{Binding Text, ElementName=AddressBarTextBox}" />
          </TextBox.InputBindings>
        </TextBox>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
          <Button Style="{StaticResource ModernButton}" Height="32" MinWidth="56" Padding="12,5" Margin="0,0,6,0"
                  Command="{Binding NavigateFromAddressBarCommand}"
                  CommandParameter="{Binding Text, ElementName=AddressBarTextBox}"
                  Content="{DynamicResource Nav.Open}"/>
          <Button Style="{StaticResource ModernButton}" Height="32" MinWidth="56" Padding="12,5" Margin="0,0,6,0"
                  Command="{Binding ReloadCommand}"
                  Content="{DynamicResource Nav.Reload}"/>
          <Button Style="{StaticResource IconButton}" Width="34" Height="32"
                  Command="{Binding ToggleFavoriteCommand}"
                  ToolTip="{Binding FavoriteToggleText}"
                  AutomationProperties.Name="{Binding FavoriteToggleText}">
            <TextBlock>
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource Mdl2IconText}">
                  <Setter Property="Text" Value="&#xE734;"/>
                  <Setter Property="FontSize" Value="13"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCurrentFavorite}" Value="True">
                      <Setter Property="Text" Value="&#xE735;"/>
                      <Setter Property="Foreground" Value="#FFC83D"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Button>
        </StackPanel>
      </Grid>

      <ProgressBar Grid.Row="1" Margin="76,6,98,0" Height="2"
                   Style="{StaticResource AddressBarProgressBar}"
                   Visibility="{Binding IsNavigating, Converter={StaticResource BoolToVisibility}}"/>
    </Grid>

    <!-- 顶栏/地址栏 与 列表区 的分隔：一条细线，不用卡片 -->
    <Grid Grid.Row="4">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,10" Opacity="0.7"/>

      <!-- Tab -->
      <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
        <RadioButton GroupName="ListTabs" Style="{StaticResource TabRadioButton}"
                     IsChecked="{Binding IsFavoritesTab, Mode=TwoWay}"
                     Margin="0,0,4,0"
                     ToolTip="{DynamicResource Fav.Tab}" AutomationProperties.Name="{DynamicResource Fav.Tab}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE734;" Margin="0,0,6,0" FontSize="13"/>
            <TextBlock Text="{DynamicResource Fav.Tab}" VerticalAlignment="Center"/>
          </StackPanel>
        </RadioButton>
        <RadioButton GroupName="ListTabs" Style="{StaticResource TabRadioButton}"
                     IsChecked="{Binding IsHistoryTab, Mode=TwoWay}"
                     ToolTip="{DynamicResource History.Tab}" AutomationProperties.Name="{DynamicResource History.Tab}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE121;" Margin="0,0,6,0" FontSize="13"/>
            <TextBlock Text="{DynamicResource History.Tab}" VerticalAlignment="Center"/>
          </StackPanel>
        </RadioButton>
      </StackPanel>

      <!-- 搜索 -->
      <TextBox x:Name="SearchBox" Grid.Row="2" Style="{StaticResource SearchTextBox}"
               Margin="0,0,0,10"
               services:Placeholder.Text="{DynamicResource Search.Placeholder}"
               services:Placeholder.Foreground="{DynamicResource TextTertiary}"
               Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
               ToolTip="{DynamicResource Search.Tooltip}"/>

      <!-- 列表：直接铺在窗口背景上，不外包一层卡片 -->
      <Grid Grid.Row="3">
        <ListBox x:Name="FavoritesListBox"
                 ItemsSource="{Binding FavoriteItems}"
                 ItemTemplate="{StaticResource BrowserListItemTemplate}"
                 MouseDoubleClick="FavoritesListBox_OnMouseDoubleClick"
                 MouseRightButtonUp="FavoritesListBox_OnRightClick"
                 KeyDown="ListBox_OnKeyDown"
                 BorderThickness="0">
          <ListBox.Style>
            <Style TargetType="ListBox" BasedOn="{StaticResource ModernListBox}">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavoritesTab}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
          <ListBox.ItemContainerStyle>
            <StaticResource ResourceKey="ModernListBoxItem"/>
          </ListBox.ItemContainerStyle>
        </ListBox>

        <ListBox x:Name="HistoryListBox"
                 ItemsSource="{Binding HistoryItems}"
                 ItemTemplate="{StaticResource BrowserListItemTemplate}"
                 MouseDoubleClick="HistoryListBox_OnMouseDoubleClick"
                 MouseRightButtonUp="HistoryListBox_OnRightClick"
                 KeyDown="ListBox_OnKeyDown"
                 BorderThickness="0">
          <ListBox.Style>
            <Style TargetType="ListBox" BasedOn="{StaticResource ModernListBox}">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Visibility" Value="Visible"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavoritesTab}" Value="True">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
          <ListBox.ItemContainerStyle>
            <StaticResource ResourceKey="ModernListBoxItem"/>
          </ListBox.ItemContainerStyle>
        </ListBox>

        <TextBlock Text="{Binding FavoritesEmptyText}"
                   FontSize="13" Foreground="{DynamicResource TextTertiary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsFavoritesTab}" Value="True"/>
                    <Condition Binding="{Binding FavoriteItems.Count}" Value="0"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <TextBlock Text="{Binding HistoryEmptyText}"
                   FontSize="13" Foreground="{DynamicResource TextTertiary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsFavoritesTab}" Value="False"/>
                    <Condition Binding="{Binding HistoryItems.Count}" Value="0"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </Grid>

    <Border Grid.RowSpan="5"
            Style="{StaticResource ToastBorderStyle}"
            Tag="{Binding IsToastVisible}"
            Visibility="{Binding ToastVisibility}"
            Background="{DynamicResource BackgroundTertiary}"
            BorderBrush="{DynamicResource AccentPrimary}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14,12"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            MaxWidth="360"
            Margin="0,0,8,8">
      <TextBlock Text="{Binding ToastMessage}" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" FontSize="12"/>
    </Border>
  </Grid>
</Window>

<Window x:Class="GenshinBrowser.Windows.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Genshin Browser Control"
        Width="640"
        Height="853"
        MinWidth="400"
        MinHeight="500"
        Background="{StaticResource BackgroundPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="Manual"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow">
  <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="{StaticResource BackgroundPrimary}">
    <Grid Margin="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="0.35*" />
        <RowDefinition Height="0.65*" />
      </Grid.RowDefinitions>

      <Grid.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </Grid.Triggers>

      <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="{StaticResource PanelPadding}" Margin="{StaticResource PanelSpacing}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="{Binding ModeToggleIcon}" Margin="0,0,8,0"/>
              <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Text="{Binding ModeText}" />
            </StackPanel>
            <TextBlock Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"
                       MaxHeight="48"
                       ToolTip="{Binding StatusMessage}" />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
            <Button Style="{StaticResource IconButton}" Margin="0,0,6,0" Command="{Binding ToggleModeCommand}" ToolTip="切换窗口模式 (F8)">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="{Binding ModeToggleIcon}"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Margin="0,0,6,0" Command="{Binding TogglePlaybackCommand}" ToolTip="控制视频播放/暂停 (K)">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE769;"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Command="{Binding NavigateHomeCommand}" ToolTip="返回原神攻略首页">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE80F;"/>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1" Style="{StaticResource PanelCard}" Padding="{StaticResource PanelPadding}" Margin="{StaticResource PanelSpacing}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
            <Button Style="{StaticResource IconButton}" Margin="0,0,6,0" Command="{Binding GoBackCommand}" ToolTip="后退">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72B;"/>
            </Button>
            <Button Style="{StaticResource IconButton}" Command="{Binding GoForwardCommand}" ToolTip="前进">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72A;"/>
            </Button>
          </StackPanel>

          <TextBox x:Name="AddressBarTextBox"
                   Grid.Column="1"
                   Style="{StaticResource ModernTextBox}"
                   ToolTip="输入网址或搜索内容，按 Enter 打开">
            <TextBox.InputBindings>
              <KeyBinding Key="Enter"
                          Command="{Binding NavigateFromAddressBarCommand}"
                          CommandParameter="{Binding Text, ElementName=AddressBarTextBox}" />
            </TextBox.InputBindings>
          </TextBox>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
            <Button Style="{StaticResource ModernButton}" MinWidth="56" Padding="10,6" Margin="0,0,6,0"
                    Command="{Binding NavigateFromAddressBarCommand}"
                    CommandParameter="{Binding Text, ElementName=AddressBarTextBox}">
              打开
            </Button>
            <Button Style="{StaticResource ModernButton}" MinWidth="56" Padding="10,6" Command="{Binding ReloadCommand}">
              刷新
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="2" Style="{StaticResource PanelCard}" Padding="{StaticResource PanelPadding}" Margin="{StaticResource PanelSpacing}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Button x:Name="FavoriteToggleButton" MinWidth="120" Command="{Binding ToggleFavoriteCommand}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsCurrentFavorite}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="{Binding FavoriteToggleIcon}" Margin="0,0,6,0"/>
              <TextBlock Text="{Binding FavoriteToggleText}"/>
            </StackPanel>
          </Button>

          <Button Grid.Column="2" Style="{StaticResource ModernButton}" Padding="10,6"
                  Command="{Binding ClearHistoryCommand}" ToolTip="清空浏览历史">
            <StackPanel Orientation="Horizontal">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE74D;" Margin="0,0,6,0"/>
              <TextBlock Text="清空历史"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{StaticResource PanelCard}" Padding="0" Margin="{StaticResource PanelSpacing}">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE734;" Margin="0,0,8,0"/>
              <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Text="收藏夹" />
            </StackPanel>

            <TextBox x:Name="FavoriteSearchBox" Grid.Column="1" Style="{StaticResource SearchTextBox}" MinWidth="96" MaxWidth="160" TextChanged="FavoriteSearchBox_OnTextChanged" ToolTip="搜索收藏" />
          </Grid>

          <Grid>
            <ListBox x:Name="FavoritesListBox"
                     Style="{StaticResource ModernListBox}"
                     ItemsSource="{Binding FavoriteItems}"
                     ItemTemplate="{StaticResource BrowserListItemTemplate}"
                     MouseDoubleClick="FavoritesListBox_OnMouseDoubleClick"
                     MouseRightButtonUp="FavoritesListBox_OnRightClick">
              <ListBox.ItemContainerStyle>
                <StaticResource ResourceKey="ModernListBoxItem"/>
              </ListBox.ItemContainerStyle>
            </ListBox>
            <TextBlock Text="{Binding FavoritesEmptyText}"
                       FontSize="12"
                       Foreground="{StaticResource TextTertiary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding FavoriteItems.Count}" Value="0">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
        </DockPanel>
      </Border>

      <Border Grid.Row="4" Style="{StaticResource PanelCard}" Padding="0">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE121;" Margin="0,0,8,0"/>
              <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Text="浏览记录" />
            </StackPanel>

            <TextBox x:Name="HistorySearchBox" Grid.Column="1" Style="{StaticResource SearchTextBox}" MinWidth="96" MaxWidth="160" TextChanged="HistorySearchBox_OnTextChanged" ToolTip="搜索历史" />
          </Grid>

          <Grid>
            <ListBox x:Name="HistoryListBox"
                     Style="{StaticResource ModernListBox}"
                     ItemsSource="{Binding HistoryItems}"
                     ItemTemplate="{StaticResource BrowserListItemTemplate}"
                     MouseDoubleClick="HistoryListBox_OnMouseDoubleClick"
                     MouseRightButtonUp="HistoryListBox_OnRightClick">
              <ListBox.ItemContainerStyle>
                <StaticResource ResourceKey="ModernListBoxItem"/>
              </ListBox.ItemContainerStyle>
            </ListBox>
            <TextBlock Text="{Binding HistoryEmptyText}"
                       FontSize="12"
                       Foreground="{StaticResource TextTertiary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HistoryItems.Count}" Value="0">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
        </DockPanel>
      </Border>

      <Border Grid.RowSpan="5"
              Style="{StaticResource ToastBorderStyle}"
              Tag="{Binding IsToastVisible}"
              Visibility="{Binding ToastVisibility}"
              Background="{StaticResource BackgroundTertiary}"
              BorderBrush="{StaticResource AccentPrimary}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12,10"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              MaxWidth="360"
              Margin="0,0,12,12">
        <TextBlock Text="{Binding ToastMessage}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
      </Border>
    </Grid>
  </Border>
</Window>

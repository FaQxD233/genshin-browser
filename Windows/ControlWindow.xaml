<Window x:Class="GenshinBrowser.Windows.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:GenshinBrowser.Models"
        xmlns:services="clr-namespace:GenshinBrowser.Services"
        Title="Genshin Browser Control"
        Width="560"
        Height="640"
        MinWidth="380"
        MinHeight="420"
        Background="{StaticResource BackgroundPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="Manual"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow">
  <Window.Resources>
    <DataTemplate x:Key="DownloadItemTemplate" DataType="{x:Type models:DownloadItem}">
      <Grid Margin="0,3">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="Medium"
                     TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextPrimary}"
                     ToolTip="{Binding FileName}"/>
          <TextBlock Grid.Column="1" Text="{Binding StateText}" FontSize="10"
                     Margin="8,0,0,0" Foreground="{StaticResource TextTertiary}"
                     VerticalAlignment="Center"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,3,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <ProgressBar Grid.Column="0" Style="{StaticResource ModernProgressBar}"
                       Value="{Binding Progress}" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="10"
                     Margin="8,0,0,0" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
          <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="26" Height="22" Margin="4,0,0,0"
                  Command="{Binding DataContext.OpenDownloadFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="打开文件"
                  IsEnabled="{Binding CanOpen}"
                  AutomationProperties.Name="打开文件">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE7B3;"/>
          </Button>
          <Button Grid.Column="3" Style="{StaticResource IconButton}" Width="26" Height="22" Margin="2,0,0,0"
                  Command="{Binding DataContext.OpenDownloadFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="打开所在文件夹"
                  IsEnabled="{Binding CanOpenInFolder}"
                  AutomationProperties.Name="打开所在文件夹">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE8DA;"/>
          </Button>
          <Button Grid.Column="4" Style="{StaticResource IconButton}" Width="26" Height="22" Margin="2,0,0,0"
                  Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="取消下载"
                  IsEnabled="{Binding CanCancel}"
                  AutomationProperties.Name="取消下载">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE711;"/>
          </Button>
        </Grid>
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid.Triggers>
      <EventTrigger RoutedEvent="FrameworkElement.Loaded">
        <BeginStoryboard>
          <Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </Grid.Triggers>

    <!-- Row 0: 状态面板（精简，无辅助文本，[?] 图标代替） -->
    <Grid Grid.Row="0" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Style="{StaticResource Mdl2IconText}" Text="{Binding ModeToggleIcon}" Margin="0,0,8,0"/>
        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Text="{Binding ModeText}" />
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Button Style="{StaticResource IconButton}" Margin="0,0,4,0" Command="{Binding ToggleModeCommand}" ToolTip="切换窗口模式 (F8)"
                AutomationProperties.Name="切换窗口模式">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="{Binding ModeToggleIcon}"/>
        </Button>
        <Button Style="{StaticResource IconButton}" Margin="0,0,4,0" Command="{Binding TogglePlaybackCommand}" ToolTip="控制视频播放/暂停 (K)"
                AutomationProperties.Name="播放或暂停">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE769;"/>
        </Button>
        <Button x:Name="SettingsButton" Margin="0,0,4,0" Click="SettingsButton_OnClick"
                ToolTip="浮窗设置" AutomationProperties.Name="浮窗设置">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsSettingsExpanded}" Value="True">
                  <Setter Property="Background" Value="{StaticResource BackgroundHover}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE713;"/>
        </Button>
        <Button x:Name="DownloadsButton" Margin="0,0,4,0" Click="DownloadsButton_OnClick"
                ToolTip="下载管理" AutomationProperties.Name="下载管理">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsDownloadsExpanded}" Value="True">
                  <Setter Property="Background" Value="{StaticResource BackgroundHover}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE896;"/>
            <TextBlock Margin="3,0,0,0" FontSize="10" Foreground="{StaticResource AccentPrimary}"
                       Text="{Binding DownloadsBadgeText}" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Row 1: 浮窗设置（可折叠面板） -->
    <Border Grid.Row="1" Background="{StaticResource BackgroundTertiary}" CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsSettingsExpanded}" Value="True">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel>
        <!-- 不透明度 -->
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="80"/>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" MinWidth="36" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="不透明度" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
          <Slider Grid.Column="1" Value="{Binding WindowOpacity, Mode=TwoWay}" Minimum="0.1" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0"/>
          <TextBlock Grid.Column="2" Text="{Binding OpacityPercentageText}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
        </Grid>

        <!-- 缩放 -->
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="80"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="页面缩放" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Style="{StaticResource ModernButton}" Width="28" Height="26" MinWidth="0" Padding="0,2"
                  Command="{Binding ZoomOutCommand}" ToolTip="缩小 (Ctrl+-)" AutomationProperties.Name="缩小">
            <TextBlock Text="-" FontSize="16" Foreground="{StaticResource TextPrimary}"/>
          </Button>
          <TextBlock Grid.Column="2" Text="{Binding ZoomPercentageText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
          <Button Grid.Column="3" Style="{StaticResource ModernButton}" Width="28" Height="26" MinWidth="0" Padding="0,2" Margin="4,0,0,0"
                  Command="{Binding ZoomInCommand}" ToolTip="放大 (Ctrl+=)" AutomationProperties.Name="放大">
            <TextBlock Text="+" FontSize="16" Foreground="{StaticResource TextPrimary}"/>
          </Button>
          <Button Grid.Column="4" Style="{StaticResource ModernButton}" Padding="8,4" Margin="6,0,0,0" Command="{Binding ResetZoomCommand}" ToolTip="重置缩放 (Ctrl+0)" FontSize="11">重置</Button>
        </Grid>

        <!-- 快捷键 -->
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="80"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto" MinWidth="80"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="切换模式" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Content="{Binding ToggleModeKeyText}" Command="{Binding RecordToggleModeKeyCommand}" Style="{StaticResource ModernButton}" HorizontalContentAlignment="Center" Margin="4,0,8,0" Padding="6,4" FontSize="11"/>
          <TextBlock Grid.Column="2" Text="播放/暂停" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
          <Button Grid.Column="3" Content="{Binding TogglePlaybackKeyText}" Command="{Binding RecordTogglePlaybackKeyCommand}" Style="{StaticResource ModernButton}" HorizontalContentAlignment="Center" Margin="4,0,0,0" Padding="6,4" FontSize="11"/>
        </Grid>

        <Button Style="{StaticResource ModernButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10,6"
                Command="{Binding RestoreDefaultSettingsCommand}" ToolTip="恢复不透明度、缩放与快捷键为默认值">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72C;" Margin="0,0,6,0"/>
            <TextBlock Text="恢复默认"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- Row 2: 下载管理（可折叠面板） -->
    <Border Grid.Row="2" Background="{StaticResource BackgroundTertiary}" CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsDownloadsExpanded}" Value="True">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Text="{Binding DownloadsEmptyText}" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Style="{StaticResource ModernButton}" Padding="8,3" FontSize="11"
                  Command="{Binding ClearFinishedDownloadsCommand}" ToolTip="清除已完成 / 已取消的记录">
            清除已结束
          </Button>
        </Grid>
        <ListBox Grid.Row="1" x:Name="DownloadsListBox"
                 Style="{StaticResource ModernListBox}"
                 MinHeight="60" MaxHeight="160"
                 ItemsSource="{Binding Downloads}"
                 ItemTemplate="{StaticResource DownloadItemTemplate}"
                 BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem" BasedOn="{StaticResource ModernListBoxItem}">
              <Setter Property="Padding" Value="8,4"/>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Grid>
    </Border>

    <!-- Row 3: 地址栏 -->
    <Grid Grid.Row="3" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,6,0">
        <Button Style="{StaticResource IconButton}" Width="36" Height="32" Margin="0,0,4,0" Command="{Binding GoBackCommand}" ToolTip="后退" AutomationProperties.Name="后退">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72B;"/>
        </Button>
        <Button Style="{StaticResource IconButton}" Width="36" Height="32" Command="{Binding GoForwardCommand}" ToolTip="前进" AutomationProperties.Name="前进">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72A;"/>
        </Button>
      </StackPanel>

      <TextBox x:Name="AddressBarTextBox"
               Grid.Column="1"
               Height="32"
               VerticalContentAlignment="Center"
               Style="{StaticResource ModernTextBox}"
               services:Placeholder.Text="输入网址或搜索内容，按 Enter 打开"
               services:Placeholder.Foreground="{StaticResource TextTertiary}"
               ToolTip="输入网址或搜索内容，按 Enter 打开">
        <TextBox.InputBindings>
          <KeyBinding Key="Enter"
                      Command="{Binding NavigateFromAddressBarCommand}"
                      CommandParameter="{Binding Text, ElementName=AddressBarTextBox}" />
        </TextBox.InputBindings>
      </TextBox>

      <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
        <Button Style="{StaticResource ModernButton}" Height="32" MinWidth="52" Padding="8,5" Margin="0,0,4,0"
                Command="{Binding NavigateFromAddressBarCommand}"
                CommandParameter="{Binding Text, ElementName=AddressBarTextBox}">
          打开
        </Button>
        <Button Style="{StaticResource ModernButton}" Height="32" MinWidth="52" Padding="8,5" Margin="0,0,4,0" Command="{Binding ReloadCommand}">
          刷新
        </Button>
        <Button Style="{StaticResource IconButton}" Width="36" Height="32"
                Command="{Binding ToggleFavoriteCommand}"
                ToolTip="{Binding FavoriteToggleText}"
                AutomationProperties.Name="{Binding FavoriteToggleText}">
          <TextBlock>
            <TextBlock.Style>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Mdl2IconText}">
                <Setter Property="Text" Value="&#xE734;"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsCurrentFavorite}" Value="True">
                    <Setter Property="Text" Value="&#xE735;"/>
                    <Setter Property="Foreground" Value="#FFC83D"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Row 5: Tab 切换 + 搜索 + 列表（独占下半部分） -->
    <Grid Grid.Row="5" Margin="0,6,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Tab 行：[收藏夹] [浏览记录] -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
        <RadioButton GroupName="ListTabs" Style="{StaticResource TabRadioButton}"
                     IsChecked="{Binding IsFavoritesTab, Mode=TwoWay}"
                     ToolTip="收藏夹" AutomationProperties.Name="收藏夹">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE734;" Margin="0,0,6,0"/>
            <TextBlock Text="收藏夹"/>
          </StackPanel>
        </RadioButton>
        <RadioButton GroupName="ListTabs" Style="{StaticResource TabRadioButton}"
                     IsChecked="{Binding IsHistoryTab, Mode=TwoWay}"
                     ToolTip="浏览记录" AutomationProperties.Name="浏览记录">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE121;" Margin="0,0,6,0"/>
            <TextBlock Text="浏览记录"/>
          </StackPanel>
        </RadioButton>
      </StackPanel>

      <!-- 搜索框：独立成行，宽度 100% -->
      <TextBox x:Name="SearchBox" Grid.Row="1" Style="{StaticResource SearchTextBox}"
               Margin="0,0,0,6"
               services:Placeholder.Text="搜索..."
               services:Placeholder.Foreground="{StaticResource TextTertiary}"
               TextChanged="SearchBox_OnTextChanged" ToolTip="搜索当前列表"/>

      <!-- 列表区：两个 ListBox 叠放，按 Tab 切换可见性 -->
      <Grid Grid.Row="2">
        <ListBox x:Name="FavoritesListBox"
                 ItemsSource="{Binding FavoriteItems}"
                 ItemTemplate="{StaticResource BrowserListItemTemplate}"
                 MouseDoubleClick="FavoritesListBox_OnMouseDoubleClick"
                 MouseRightButtonUp="FavoritesListBox_OnRightClick">
          <ListBox.Style>
            <Style TargetType="ListBox" BasedOn="{StaticResource ModernListBox}">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavoritesTab}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
          <ListBox.ItemContainerStyle>
            <StaticResource ResourceKey="ModernListBoxItem"/>
          </ListBox.ItemContainerStyle>
        </ListBox>

        <ListBox x:Name="HistoryListBox"
                 ItemsSource="{Binding HistoryItems}"
                 ItemTemplate="{StaticResource BrowserListItemTemplate}"
                 MouseDoubleClick="HistoryListBox_OnMouseDoubleClick"
                 MouseRightButtonUp="HistoryListBox_OnRightClick">
          <ListBox.Style>
            <Style TargetType="ListBox" BasedOn="{StaticResource ModernListBox}">
              <Setter Property="Visibility" Value="Visible"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavoritesTab}" Value="True">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
          <ListBox.ItemContainerStyle>
            <StaticResource ResourceKey="ModernListBoxItem"/>
          </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- 收藏夹空列表提示 -->
        <TextBlock Text="{Binding FavoritesEmptyText}"
                   FontSize="12" Foreground="{StaticResource TextTertiary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsFavoritesTab}" Value="True"/>
                    <Condition Binding="{Binding FavoriteItems.Count}" Value="0"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <!-- 历史空列表提示 -->
        <TextBlock Text="{Binding HistoryEmptyText}"
                   FontSize="12" Foreground="{StaticResource TextTertiary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsFavoritesTab}" Value="False"/>
                    <Condition Binding="{Binding HistoryItems.Count}" Value="0"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </Grid>

    <Border Grid.RowSpan="6"
            Style="{StaticResource ToastBorderStyle}"
            Tag="{Binding IsToastVisible}"
            Visibility="{Binding ToastVisibility}"
            Background="{StaticResource BackgroundTertiary}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12,10"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            MaxWidth="360"
            Margin="0,0,4,4">
      <TextBlock Text="{Binding ToastMessage}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
    </Border>
  </Grid>
</Window>

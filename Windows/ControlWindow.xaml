<Window x:Class="GenshinBrowser.Windows.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Genshin Browser Control"
        Width="640"
        Height="853"
        MinWidth="400"
        MinHeight="500"
        Background="#0F1419"
        Foreground="#E6EDF3"
        WindowStartupLocation="Manual"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow">
  <Window.Resources>
    <!-- 配色定义 -->
    <SolidColorBrush x:Key="BackgroundPrimary" Color="#0F1419"/>
    <SolidColorBrush x:Key="BackgroundSecondary" Color="#1C2128"/>
    <SolidColorBrush x:Key="BackgroundTertiary" Color="#2D333B"/>
    <SolidColorBrush x:Key="BorderColor" Color="#444C56"/>
    <SolidColorBrush x:Key="AccentPrimary" Color="#58A6FF"/>
    <SolidColorBrush x:Key="AccentSuccess" Color="#3FB950"/>
    <SolidColorBrush x:Key="AccentDanger" Color="#F85149"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
    <SolidColorBrush x:Key="TextTertiary" Color="#6E7681"/>

    <!-- 按钮样式 -->
    <Style x:Key="ModernButton" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#373E47"/>
          <Setter Property="BorderBrush" Value="#8B949E"/>
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#444C56"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- 主要操作按钮 -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
      <Setter Property="Background" Value="#238636"/>
      <Setter Property="BorderBrush" Value="#2EA043"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2EA043"/>
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#238636"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- 图标按钮 -->
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
      <Setter Property="MinWidth" Value="36"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- 地址栏样式 -->
    <Style x:Key="ModernTextBox" TargetType="TextBox">
      <Setter Property="Background" Value="{StaticResource BackgroundSecondary}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="CaretBrush" Value="{StaticResource AccentPrimary}"/>
      <Setter Property="SelectionBrush" Value="#264F78"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ScrollViewer x:Name="PART_ContentHost"
                          Padding="{TemplateBinding Padding}"
                          VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
          <Setter Property="BorderThickness" Value="2"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- 搜索框样式 -->
    <Style x:Key="SearchTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="10,6"/>
    </Style>

    <!-- 列表框样式 -->
    <Style x:Key="ModernListBox" TargetType="ListBox">
      <Setter Property="Background" Value="{StaticResource BackgroundSecondary}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
      <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
      <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
      <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
    </Style>

    <!-- 列表项样式 -->
    <Style x:Key="ModernListBoxItem" TargetType="ListBoxItem">
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="BorderBrush" Value="#21262D"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#1C2128"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#2D333B"/>
          <Setter Property="Foreground" Value="{StaticResource AccentPrimary}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="{StaticResource BackgroundPrimary}">
    <Grid Margin="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="0.35*" />
        <RowDefinition Height="0.65*" />
      </Grid.RowDefinitions>

      <!-- 顶部状态栏 -->
      <Border Grid.Row="0" Background="{StaticResource BackgroundSecondary}"
              Padding="12,10" CornerRadius="6" Margin="0,0,0,8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock x:Name="ModeTextBlock"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Text="自由模式" />
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       Text="正在初始化浏览器..."
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"
                       MaxHeight="48"
                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
            <Button x:Name="ToggleModeButton"
                    Style="{StaticResource IconButton}"
                    Margin="0,0,6,0"
                    Click="ToggleModeButton_OnClick"
                    ToolTip="切换窗口模式">
              📌
            </Button>
            <Button x:Name="PlayPauseButton"
                    Style="{StaticResource IconButton}"
                    Margin="0,0,6,0"
                    Click="PlayPauseButton_OnClick"
                    ToolTip="控制视频播放">
              ⏯
            </Button>
            <Button x:Name="HomeButton"
                    Style="{StaticResource IconButton}"
                    Click="HomeButton_OnClick"
                    ToolTip="返回原神攻略首页">
              🏠
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 地址栏 -->
      <Border Grid.Row="1" Background="{StaticResource BackgroundSecondary}"
              Padding="12,10" CornerRadius="6" Margin="0,0,0,8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBox x:Name="AddressBarTextBox"
                   Style="{StaticResource ModernTextBox}"
                   KeyDown="AddressBarTextBox_OnKeyDown"
                   ToolTip="输入网址或搜索内容，按 Enter 打开" />

          <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
            <Button Style="{StaticResource ModernButton}"
                    MinWidth="56"
                    Padding="10,6"
                    Margin="0,0,6,0"
                    Click="GoButton_OnClick">
              打开
            </Button>
            <Button Style="{StaticResource ModernButton}"
                    MinWidth="56"
                    Padding="10,6"
                    Click="ReloadButton_OnClick">
              刷新
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 快捷操作栏 -->
      <Border Grid.Row="2" Background="{StaticResource BackgroundSecondary}"
              Padding="12,10" CornerRadius="6" Margin="0,0,0,8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Button x:Name="FavoriteToggleButton"
                  Style="{StaticResource PrimaryButton}"
                  MinWidth="100"
                  Click="FavoriteToggleButton_OnClick">
            ⭐ 收藏当前页
          </Button>

          <Button Grid.Column="2"
                  x:Name="ClearHistoryButton"
                  Style="{StaticResource ModernButton}"
                  Padding="10,6"
                  Click="ClearHistoryButton_OnClick"
                  ToolTip="清空浏览历史">
            🗑 清空历史
          </Button>
        </Grid>
      </Border>

      <!-- 收藏夹 -->
      <Border Grid.Row="3" Background="{StaticResource BackgroundSecondary}"
              CornerRadius="6" Padding="0" Margin="0,0,0,8">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}">
              ⭐ 收藏夹
            </TextBlock>

            <TextBox x:Name="FavoriteSearchBox"
                     Grid.Column="1"
                     Style="{StaticResource SearchTextBox}"
                     Width="140"
                     TextChanged="FavoriteSearchBox_OnTextChanged"
                     ToolTip="搜索收藏" />
          </Grid>

          <ListBox x:Name="FavoritesListBox"
                   Style="{StaticResource ModernListBox}"
                   MouseDoubleClick="FavoritesListBox_OnMouseDoubleClick"
                   MouseRightButtonUp="FavoritesListBox_OnRightClick">
            <ListBox.ItemContainerStyle>
              <StaticResource ResourceKey="ModernListBoxItem"/>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock Text="{Binding Title}"
                             FontSize="12"
                             FontWeight="Medium"
                             TextTrimming="CharacterEllipsis"
                             Foreground="{StaticResource TextPrimary}"/>
                  <TextBlock Grid.Row="1"
                             Text="{Binding TimeDisplay}"
                             FontSize="10"
                             Margin="0,2,0,0"
                             Foreground="{StaticResource TextTertiary}"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- 浏览记录 -->
      <Border Grid.Row="4" Background="{StaticResource BackgroundSecondary}"
              CornerRadius="6" Padding="0">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}">
              🕒 浏览记录
            </TextBlock>

            <TextBox x:Name="HistorySearchBox"
                     Grid.Column="1"
                     Style="{StaticResource SearchTextBox}"
                     Width="140"
                     TextChanged="HistorySearchBox_OnTextChanged"
                     ToolTip="搜索历史" />
          </Grid>

          <ListBox x:Name="HistoryListBox"
                   Style="{StaticResource ModernListBox}"
                   MouseDoubleClick="HistoryListBox_OnMouseDoubleClick"
                   MouseRightButtonUp="HistoryListBox_OnRightClick">
            <ListBox.ItemContainerStyle>
              <StaticResource ResourceKey="ModernListBoxItem"/>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock Text="{Binding Title}"
                             FontSize="12"
                             FontWeight="Medium"
                             TextTrimming="CharacterEllipsis"
                             Foreground="{StaticResource TextPrimary}"/>
                  <TextBlock Grid.Row="1"
                             Text="{Binding TimeDisplay}"
                             FontSize="10"
                             Margin="0,2,0,0"
                             Foreground="{StaticResource TextTertiary}"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>
    </Grid>
  </Border>
</Window>

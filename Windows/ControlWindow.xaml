<Window x:Class="GenshinBrowser.Windows.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Genshin Browser Control"
        Width="320"
        Height="520"
        MinWidth="280"
        MinHeight="340"
        Background="#171B24"
        Foreground="#F4F6FB"
        WindowStartupLocation="Manual">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#171B24" Padding="4,2,4,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock x:Name="ModeTextBlock" FontSize="14" FontWeight="SemiBold" Text="自由模式" />
          <TextBlock x:Name="StatusTextBlock" Margin="0,2,0,0" FontSize="11" Foreground="#9BA7BF" Text="正在初始化浏览器..." TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
          <Button x:Name="ToggleModeButton" MinWidth="52" Margin="0,0,6,0" Padding="8,4" FontSize="11" Click="ToggleModeButton_OnClick">切换模式</Button>
          <Button x:Name="PlayPauseButton" MinWidth="52" Margin="0,0,6,0" Padding="8,4" FontSize="11" Click="PlayPauseButton_OnClick">播放/暂停</Button>
          <Button x:Name="HomeButton" MinWidth="52" Padding="8,4" FontSize="11" Click="HomeButton_OnClick">原神攻略</Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="#11151D" Padding="8,6" Margin="0,0,0,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBox x:Name="AddressBarTextBox"
                 Padding="8,4"
                 FontSize="11"
                 BorderThickness="0"
                 Background="#202634"
                 Foreground="#F4F6FB"
                 KeyDown="AddressBarTextBox_OnKeyDown" />

        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
          <Button MinWidth="48" Padding="8,4" Margin="0,0,6,0" FontSize="11" Click="GoButton_OnClick">打开</Button>
          <Button MinWidth="48" Padding="8,4" FontSize="11" Click="ReloadButton_OnClick">刷新</Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="2" Background="#171B24" Padding="0,0,0,8">
      <DockPanel>
        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="收藏夹" />
          <Button x:Name="FavoriteToggleButton" Grid.Column="1" MinWidth="84" Padding="8,4" FontSize="11" Click="FavoriteToggleButton_OnClick">收藏当前页</Button>
        </Grid>

        <ListBox x:Name="FavoritesListBox"
                 FontSize="11"
                 Background="#11151D"
                 BorderThickness="0"
                 Foreground="#F4F6FB"
                 MouseDoubleClick="FavoritesListBox_OnMouseDoubleClick"
                 DisplayMemberPath="DisplayText" />
      </DockPanel>
    </Border>

    <Border Grid.Row="3" Background="#171B24" Padding="0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="12" FontWeight="SemiBold" Text="浏览记录" />
        <ListBox x:Name="HistoryListBox"
                 FontSize="11"
                 Background="#11151D"
                 BorderThickness="0"
                 Foreground="#F4F6FB"
                 MouseDoubleClick="HistoryListBox_OnMouseDoubleClick"
                 DisplayMemberPath="DisplayText" />
      </DockPanel>
    </Border>
  </Grid>
</Window>

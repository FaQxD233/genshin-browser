<Window x:Class="GenshinBrowser.Windows.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:GenshinBrowser.Models"
        xmlns:services="clr-namespace:GenshinBrowser.Services"
        Title="{DynamicResource Control.Title}"
        Width="560"
        Height="640"
        MinWidth="400"
        MinHeight="440"
        Background="{DynamicResource BackgroundPrimary}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="Manual"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow"
        Focusable="True">
  <Window.Resources>
    <services:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

    <DataTemplate x:Key="DownloadItemTemplate" DataType="{x:Type models:DownloadItem}">
      <Grid Margin="0,4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="Medium"
                     TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimary}"
                     ToolTip="{Binding FileName}" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1" Text="{Binding StateText}" FontSize="11"
                     Margin="12,0,0,0" Foreground="{DynamicResource TextTertiary}"
                     VerticalAlignment="Center"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,6,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <ProgressBar Grid.Column="0" Style="{StaticResource ModernProgressBar}"
                       Value="{Binding Progress}" VerticalAlignment="Center" Height="5"/>
          <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="11"
                     Margin="10,0,0,0" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
          <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="24" Margin="8,0,0,0"
                  Command="{Binding DataContext.OpenDownloadFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="{DynamicResource Downloads.OpenFile}"
                  IsEnabled="{Binding CanOpen}"
                  AutomationProperties.Name="{DynamicResource Downloads.OpenFile}">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE7B3;" FontSize="12"/>
          </Button>
          <Button Grid.Column="3" Style="{StaticResource IconButton}" Width="28" Height="24" Margin="4,0,0,0"
                  Command="{Binding DataContext.OpenDownloadFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="{DynamicResource Downloads.OpenFolder}"
                  IsEnabled="{Binding CanOpenInFolder}"
                  AutomationProperties.Name="{DynamicResource Downloads.OpenFolder}">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE8DA;" FontSize="12"/>
          </Button>
          <Button Grid.Column="4" Style="{StaticResource IconButton}" Width="28" Height="24" Margin="4,0,0,0"
                  Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  ToolTip="{DynamicResource Downloads.Cancel}"
                  IsEnabled="{Binding CanCancel}"
                  AutomationProperties.Name="{DynamicResource Downloads.Cancel}">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE711;" FontSize="12"/>
          </Button>
        </Grid>
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Grid Margin="16,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid.Triggers>
      <EventTrigger RoutedEvent="FrameworkElement.Loaded">
        <BeginStoryboard>
          <Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </Grid.Triggers>

    <!-- Row 0: 顶栏 — 左侧 浏览|浮窗 分段，右侧工具 -->
    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Border HorizontalAlignment="Left"
              Background="{DynamicResource BackgroundSecondary}"
              BorderBrush="{DynamicResource BorderColor}"
              BorderThickness="1"
              CornerRadius="14"
              Padding="3"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <Button Command="{Binding SetBrowsingModeCommand}"
                  Content="{DynamicResource Mode.Free}"
                  ToolTip="{Binding SwitchToBrowsingTooltip}"
                  AutomationProperties.Name="{DynamicResource Mode.Free}"
                  MinWidth="56" Height="26" Padding="10,0" FontSize="12" FontWeight="SemiBold"
                  Cursor="Hand">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource SegmentButton}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsBrowsingMode}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
          <Button Command="{Binding SetFloatingModeCommand}"
                  Content="{DynamicResource Mode.Fixed}"
                  ToolTip="{Binding SwitchToFloatingTooltip}"
                  AutomationProperties.Name="{DynamicResource Mode.Fixed}"
                  MinWidth="56" Height="26" Padding="10,0" FontSize="12" FontWeight="SemiBold"
                  Cursor="Hand" Margin="2,0,0,0">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource SegmentButton}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFloatingMode}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ModeFloatingAccentSoft}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ModeFloatingAccent}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </StackPanel>
      </Border>

      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Button Style="{StaticResource IconButton}" Width="34" Height="30" Margin="0,0,6,0" Padding="0"
                Command="{Binding TogglePlaybackCommand}" ToolTip="{Binding PlaybackTooltip}"
                AutomationProperties.Name="{DynamicResource Toolbar.PlaybackName}">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE769;" FontSize="13"/>
        </Button>
        <Button x:Name="SettingsButton" Width="34" Height="30" Margin="0,0,6,0" Padding="0"
                Command="{Binding ToggleSettingsCommand}"
                ToolTip="{DynamicResource Toolbar.SettingsTooltip}" AutomationProperties.Name="{DynamicResource Toolbar.SettingsName}">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
              <Setter Property="Padding" Value="0"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsSettingsExpanded}" Value="True">
                  <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE713;" FontSize="13"/>
        </Button>
        <Button x:Name="DownloadsButton" Width="34" Height="30" Padding="0"
                Command="{Binding ToggleDownloadsCommand}"
                ToolTip="{DynamicResource Toolbar.DownloadsTooltip}" AutomationProperties.Name="{DynamicResource Toolbar.DownloadsName}">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
              <Setter Property="Padding" Value="0"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsDownloadsExpanded}" Value="True">
                  <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <Grid Width="18" Height="18">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE896;" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Border Visibility="{Binding HasDownloadsBadge, Converter={StaticResource BoolToVisibility}}">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource DownloadsBadgeBorder}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HasInterruptedDownloads}" Value="True">
                      <Setter Property="Background" Value="{DynamicResource AccentDanger}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock Text="{Binding DownloadsBadgeText}"
                         FontSize="9" FontWeight="SemiBold"
                         Foreground="White"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Grid>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Row 1: 设置面板
         外层透明壳只负责 MaxHeight 动画（折叠=0，不占位）；
         内层才是可见底色，Margin 底 12 在壳内，折叠时一并被裁掉 -->
    <Border Grid.Row="1" x:Name="SettingsPanelBorder"
            Background="Transparent"
            Margin="0" Padding="0"
            ClipToBounds="True" MaxHeight="0" Opacity="0">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsSettingsExpanded}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight" To="340" Duration="0:0:0.2"
                                     EasingFunction="{StaticResource EaseOutCubic}"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.14"/>
                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight" To="0" Duration="0:0:0.16"
                                     EasingFunction="{StaticResource EaseOutCubic}"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.ExitActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <Border Background="{DynamicResource BackgroundSecondary}"
              CornerRadius="6"
              Padding="10,8"
              Margin="0,0,0,12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource Settings.Title}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button Style="{StaticResource ModernButton}"
                      HorizontalAlignment="Right" VerticalAlignment="Center"
                      Padding="8,3" Height="24" FontSize="11" Margin="0,0,6,0"
                      Command="{Binding ClearBrowsingDataCommand}"
                      ToolTip="{DynamicResource Settings.ClearBrowsingDataTooltip}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE74D;" Margin="0,0,5,0" FontSize="11"/>
                  <TextBlock Text="{DynamicResource Settings.ClearBrowsingData}" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource ModernButton}"
                      HorizontalAlignment="Right" VerticalAlignment="Center"
                      Padding="8,3" Height="24" FontSize="11"
                      Command="{Binding RestoreDefaultSettingsCommand}"
                      ToolTip="{DynamicResource Settings.RestoreDefaultsTooltip}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72C;" Margin="0,0,5,0" FontSize="11"/>
                  <TextBlock Text="{DynamicResource Settings.RestoreDefaults}" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>
          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        MaxHeight="280"
                        Padding="0,0,2,0">
            <StackPanel>
              <!-- 分组：窗口 -->
              <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="{DynamicResource Settings.Window}" Margin="0,0,0,8"/>
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="68"/>
                  <ColumnDefinition Width="58"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="58"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Settings.WindowSize}" Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBox x:Name="BrowserWindowWidthBox" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                         Height="26" Padding="6,2" FontSize="11"
                         VerticalContentAlignment="Center"
                         ToolTip="{DynamicResource Settings.Width}"
                         Text="{Binding BrowserWindowWidthText, UpdateSourceTrigger=PropertyChanged}">
                  <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding ApplyWindowSizeCommand}"/>
                  </TextBox.InputBindings>
                </TextBox>
                <TextBlock Grid.Column="2" Text="×" Foreground="{DynamicResource TextTertiary}"
                           FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                <TextBox x:Name="BrowserWindowHeightBox" Grid.Column="3" Style="{StaticResource ModernTextBox}"
                         Height="26" Padding="6,2" FontSize="11"
                         VerticalContentAlignment="Center"
                         ToolTip="{DynamicResource Settings.Height}"
                         Text="{Binding BrowserWindowHeightText, UpdateSourceTrigger=PropertyChanged}">
                  <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding ApplyWindowSizeCommand}"/>
                  </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="4" Style="{StaticResource ModernButton}" Padding="10,3" Margin="6,0,0,0"
                        FontSize="11" Height="26"
                        Command="{Binding ApplyWindowSizeCommand}"
                        Content="{DynamicResource Settings.ApplySize}"
                        ToolTip="{DynamicResource Settings.ApplySizeTooltip}"/>
              </Grid>

              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="68"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Settings.MoveCorner}" Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" VerticalAlignment="Center"/>
                <!-- ↖↗↙↘ 方向一目了然，避免 MDL2 图标语义错位 -->
                <Button Grid.Column="1" Style="{StaticResource ModernButton}" Height="26" Margin="0,0,4,0"
                        Padding="0" FontSize="14" FontWeight="SemiBold"
                        Command="{Binding MoveBrowserToCornerCommand}" CommandParameter="TopLeft"
                        Content="↖"
                        ToolTip="{DynamicResource Settings.MoveTopLeftTooltip}"
                        AutomationProperties.Name="{DynamicResource Settings.MoveTopLeft}"/>
                <Button Grid.Column="2" Style="{StaticResource ModernButton}" Height="26" Margin="0,0,4,0"
                        Padding="0" FontSize="14" FontWeight="SemiBold"
                        Command="{Binding MoveBrowserToCornerCommand}" CommandParameter="TopRight"
                        Content="↗"
                        ToolTip="{DynamicResource Settings.MoveTopRightTooltip}"
                        AutomationProperties.Name="{DynamicResource Settings.MoveTopRight}"/>
                <Button Grid.Column="3" Style="{StaticResource ModernButton}" Height="26" Margin="0,0,4,0"
                        Padding="0" FontSize="14" FontWeight="SemiBold"
                        Command="{Binding MoveBrowserToCornerCommand}" CommandParameter="BottomLeft"
                        Content="↙"
                        ToolTip="{DynamicResource Settings.MoveBottomLeftTooltip}"
                        AutomationProperties.Name="{DynamicResource Settings.MoveBottomLeft}"/>
                <Button Grid.Column="4" Style="{StaticResource ModernButton}" Height="26"
                        Padding="0" FontSize="14" FontWeight="SemiBold"
                        Command="{Binding MoveBrowserToCornerCommand}" CommandParameter="BottomRight"
                        Content="↘"
                        ToolTip="{DynamicResource Settings.MoveBottomRightTooltip}"
                        AutomationProperties.Name="{DynamicResource Settings.MoveBottomRight}"/>
              </Grid>

              <!-- 分组：显示 — 不透明度 / 页面缩放同一行：− 数值 % + 重置 -->
              <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="{DynamicResource Settings.Display}"/>
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="12"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- 不透明度组：label − [输入] % + 重置 -->
                <Grid Grid.Column="0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Opacity}" Foreground="{DynamicResource TextSecondary}"
                             FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <Button Grid.Column="1" Style="{StaticResource ModernButton}" Width="28" Height="26" MinWidth="0" Padding="0"
                          Command="{Binding OpacityOutCommand}" ToolTip="{DynamicResource Settings.OpacityOutTooltip}">
                    <TextBlock Text="−" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                  </Button>
                  <TextBox x:Name="OpacityPercentBox" Grid.Column="2" Style="{StaticResource ModernTextBox}"
                           Height="26" Padding="2,2" FontSize="11" Margin="4,0"
                           VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                           Text="{Binding OpacityPercentText, UpdateSourceTrigger=PropertyChanged}"
                           LostKeyboardFocus="OpacityPercentBox_OnLostKeyboardFocus">
                    <TextBox.InputBindings>
                      <KeyBinding Key="Enter" Command="{Binding ApplyOpacityCommand}"/>
                    </TextBox.InputBindings>
                  </TextBox>
                  <TextBlock Grid.Column="3" Text="{DynamicResource Settings.PercentUnit}"
                             FontSize="11" Foreground="{DynamicResource TextTertiary}"
                             VerticalAlignment="Center"/>
                  <Button Grid.Column="4" Style="{StaticResource ModernButton}" Width="28" Height="26" MinWidth="0" Padding="0" Margin="4,0,0,0"
                          Command="{Binding OpacityInCommand}" ToolTip="{DynamicResource Settings.OpacityInTooltip}">
                    <TextBlock Text="+" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                  </Button>
                  <Button Grid.Column="5" Style="{StaticResource ModernButton}" Padding="8,3" Margin="4,0,0,0"
                          Height="26" FontSize="11"
                          Command="{Binding ResetOpacityCommand}" ToolTip="{DynamicResource Settings.OpacityResetTooltip}"
                          Content="{DynamicResource Settings.ZoomReset}"/>
                </Grid>
                <!-- 缩放组：label − [输入] % + 重置 -->
                <Grid Grid.Column="2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Zoom}" Foreground="{DynamicResource TextSecondary}"
                             FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <Button Grid.Column="1" Style="{StaticResource ModernButton}" Width="28" Height="26" MinWidth="0" Padding="0"
                          Command="{Binding ZoomOutCommand}" ToolTip="{DynamicResource Settings.ZoomOutTooltip}">
                    <TextBlock Text="−" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                  </Button>
                  <TextBox x:Name="ZoomPercentBox" Grid.Column="2" Style="{StaticResource ModernTextBox}"
                           Height="26" Padding="2,2" FontSize="11" Margin="4,0"
                           VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                           Text="{Binding ZoomPercentText, UpdateSourceTrigger=PropertyChanged}"
                           LostKeyboardFocus="ZoomPercentBox_OnLostKeyboardFocus">
                    <TextBox.InputBindings>
                      <KeyBinding Key="Enter" Command="{Binding ApplyZoomCommand}"/>
                    </TextBox.InputBindings>
                  </TextBox>
                  <TextBlock Grid.Column="3" Text="{DynamicResource Settings.PercentUnit}"
                             FontSize="11" Foreground="{DynamicResource TextTertiary}"
                             VerticalAlignment="Center"/>
                  <Button Grid.Column="4" Style="{StaticResource ModernButton}" Width="28" Height="26" MinWidth="0" Padding="0" Margin="4,0,0,0"
                          Command="{Binding ZoomInCommand}" ToolTip="{DynamicResource Settings.ZoomInTooltip}">
                    <TextBlock Text="+" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                  </Button>
                  <Button Grid.Column="5" Style="{StaticResource ModernButton}" Padding="8,3" Margin="4,0,0,0"
                          Height="26" FontSize="11"
                          Command="{Binding ResetZoomCommand}" ToolTip="{DynamicResource Settings.ZoomResetTooltip}"
                          Content="{DynamicResource Settings.ZoomReset}"/>
                </Grid>
              </Grid>

              <!-- 分组：外观 + 快捷键 -->
              <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="{DynamicResource Settings.Appearance}"/>
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="68"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="12"/>
                  <ColumnDefinition Width="68"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Theme}" Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Margin="0,0,4,0" Command="{Binding SetThemeDarkCommand}" Content="{DynamicResource Settings.ThemeDark}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SegmentButton}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsThemeDark}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                          <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                          <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <Button Grid.Column="2" Command="{Binding SetThemeLightCommand}" Content="{DynamicResource Settings.ThemeLight}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SegmentButton}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsThemeLight}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                          <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                          <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <TextBlock Grid.Column="4" Text="{DynamicResource Settings.Language}" Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="5" Margin="0,0,4,0" Command="{Binding SetLanguageZhCommand}" Content="{DynamicResource Settings.LanguageZh}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SegmentButton}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLanguageZh}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                          <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                          <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <Button Grid.Column="6" Command="{Binding SetLanguageEnCommand}" Content="{DynamicResource Settings.LanguageEn}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SegmentButton}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLanguageEn}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                          <Setter Property="Background" Value="{DynamicResource BackgroundHover}"/>
                          <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </Grid>

              <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="{DynamicResource Settings.Hotkeys}"/>
              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="68"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="8"/>
                  <ColumnDefinition Width="68"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Settings.ToggleMode}" Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="{Binding ToggleModeKeyText}"
                        Command="{Binding RecordToggleModeKeyCommand}"
                        Style="{StaticResource ModernButton}" HorizontalContentAlignment="Center"
                        Height="26" Padding="6,2" FontSize="11"/>
                <TextBlock Grid.Column="3" Text="{DynamicResource Settings.Playback}" Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="4" Content="{Binding TogglePlaybackKeyText}"
                        Command="{Binding RecordTogglePlaybackKeyCommand}"
                        Style="{StaticResource ModernButton}" HorizontalContentAlignment="Center"
                        Height="26" Padding="6,2" FontSize="11"/>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Border>

    <!-- Row 2: 下载面板 — 与设置同一双层结构 -->
    <Border Grid.Row="2" x:Name="DownloadsPanelBorder"
            Background="Transparent"
            Margin="0" Padding="0"
            ClipToBounds="True" MaxHeight="0" Opacity="0">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsDownloadsExpanded}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight" To="260" Duration="0:0:0.2"
                                     EasingFunction="{StaticResource EaseOutCubic}"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.14"/>
                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight" To="0" Duration="0:0:0.16"
                                     EasingFunction="{StaticResource EaseOutCubic}"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.ExitActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <Border Background="{DynamicResource BackgroundSecondary}"
              CornerRadius="6"
              Padding="12"
              Margin="0,0,0,12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource Downloads.Title}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Padding="10,5" FontSize="11"
                    Command="{Binding ClearFinishedDownloadsCommand}"
                    ToolTip="{DynamicResource Downloads.ClearFinishedTooltip}"
                    Content="{DynamicResource Downloads.ClearFinished}"/>
          </Grid>
          <Grid Grid.Row="1" MinHeight="72" MaxHeight="168">
            <ListBox x:Name="DownloadsListBox"
                     Style="{StaticResource ModernListBox}"
                     ItemsSource="{Binding Downloads}"
                     ItemTemplate="{StaticResource DownloadItemTemplate}"
                     Background="Transparent"
                     BorderThickness="0">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource ModernListBoxItem}">
                  <Setter Property="Padding" Value="8,6"/>
                </Style>
              </ListBox.ItemContainerStyle>
            </ListBox>
            <TextBlock Text="{Binding DownloadsEmptyText}"
                       FontSize="13" Foreground="{DynamicResource TextTertiary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap" LineHeight="20"
                       MaxWidth="280" IsHitTestVisible="False"
                       Visibility="{Binding HasNoDownloads, Converter={StaticResource BoolToVisibility}}"/>
          </Grid>
        </Grid>
      </Border>
    </Border>

    <!-- Row 3: 地址栏 — 主次动作分层；进度条与地址框对齐 -->
    <Grid Grid.Row="3" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Top">
        <Button Style="{StaticResource IconButton}" Width="34" Height="32" Margin="0,0,6,0"
                Command="{Binding GoBackCommand}"
                IsEnabled="{Binding CanGoBack}"
                ToolTip="{DynamicResource Nav.Back}" AutomationProperties.Name="{DynamicResource Nav.Back}">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72B;" FontSize="13"/>
        </Button>
        <Button Style="{StaticResource IconButton}" Width="34" Height="32"
                Command="{Binding GoForwardCommand}"
                IsEnabled="{Binding CanGoForward}"
                ToolTip="{DynamicResource Nav.Forward}" AutomationProperties.Name="{DynamicResource Nav.Forward}">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72A;" FontSize="13"/>
        </Button>
      </StackPanel>

      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="AddressBarTextBox"
                 Grid.Row="0"
                 Height="32"
                 VerticalContentAlignment="Center"
                 Style="{StaticResource ModernTextBox}"
                 services:Placeholder.Text="{DynamicResource Nav.AddressPlaceholder}"
                 services:Placeholder.Foreground="{DynamicResource TextTertiary}"
                 ToolTip="{DynamicResource Nav.AddressTooltip}">
          <TextBox.InputBindings>
            <KeyBinding Key="Enter"
                        Command="{Binding NavigateFromAddressBarCommand}"
                        CommandParameter="{Binding Text, ElementName=AddressBarTextBox}" />
          </TextBox.InputBindings>
        </TextBox>
        <ProgressBar Grid.Row="1" Margin="0,4,0,0" Height="2"
                     Style="{StaticResource AddressBarProgressBar}"
                     Visibility="{Binding IsNavigating, Converter={StaticResource BoolToVisibility}}"/>
      </Grid>

      <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Top">
        <Button Style="{StaticResource PrimaryButton}" Height="32" MinWidth="56" Padding="12,5" Margin="0,0,6,0"
                Command="{Binding NavigateFromAddressBarCommand}"
                CommandParameter="{Binding Text, ElementName=AddressBarTextBox}"
                Content="{DynamicResource Nav.Open}"
                ToolTip="{DynamicResource Nav.Open}"/>
        <Button Style="{StaticResource IconButton}" Width="34" Height="32" Margin="0,0,6,0" Padding="0"
                Command="{Binding ReloadCommand}"
                ToolTip="{DynamicResource Nav.Reload}" AutomationProperties.Name="{DynamicResource Nav.Reload}">
          <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE72C;" FontSize="13"/>
        </Button>
        <Button Style="{StaticResource IconButton}" Width="34" Height="32" Padding="0"
                Command="{Binding ToggleFavoriteCommand}"
                ToolTip="{Binding FavoriteToggleText}"
                AutomationProperties.Name="{Binding FavoriteToggleText}">
          <TextBlock>
            <TextBlock.Style>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Mdl2IconText}">
                <Setter Property="Text" Value="&#xE734;"/>
                <Setter Property="FontSize" Value="13"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsCurrentFavorite}" Value="True">
                    <Setter Property="Text" Value="&#xE735;"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentWarning}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Button>
      </StackPanel>
    </Grid>

    <!-- 顶栏/地址栏 与 列表区 的分隔：一条细线，不用卡片 -->
    <Grid Grid.Row="4">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,10" Opacity="0.7"/>

      <!-- Tab -->
      <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
        <RadioButton GroupName="ListTabs" Style="{StaticResource TabRadioButton}"
                     IsChecked="{Binding IsFavoritesTab, Mode=TwoWay}"
                     Margin="0,0,4,0"
                     ToolTip="{DynamicResource Fav.Tab}" AutomationProperties.Name="{DynamicResource Fav.Tab}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE734;" Margin="0,0,6,0" FontSize="13"/>
            <TextBlock Text="{DynamicResource Fav.Tab}" VerticalAlignment="Center"/>
          </StackPanel>
        </RadioButton>
        <RadioButton GroupName="ListTabs" Style="{StaticResource TabRadioButton}"
                     IsChecked="{Binding IsHistoryTab, Mode=TwoWay}"
                     ToolTip="{DynamicResource History.Tab}" AutomationProperties.Name="{DynamicResource History.Tab}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE121;" Margin="0,0,6,0" FontSize="13"/>
            <TextBlock Text="{DynamicResource History.Tab}" VerticalAlignment="Center"/>
          </StackPanel>
        </RadioButton>
      </StackPanel>

      <!-- 搜索 -->
      <Grid Grid.Row="2" Margin="0,0,0,10">
        <TextBox x:Name="SearchBox" Style="{StaticResource SearchTextBox}"
                 Padding="28,8,12,8"
                 services:Placeholder.Text="{DynamicResource Search.Placeholder}"
                 services:Placeholder.Foreground="{DynamicResource TextTertiary}"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="{DynamicResource Search.Tooltip}"/>
        <TextBlock Style="{StaticResource Mdl2IconText}" Text="&#xE721;"
                   FontSize="13" Foreground="{DynamicResource TextTertiary}"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   Margin="12,0,0,0" IsHitTestVisible="False"/>
      </Grid>

      <!-- 列表：直接铺在窗口背景上，不外包一层卡片 -->
      <Grid Grid.Row="3">
        <ListBox x:Name="FavoritesListBox"
                 ItemsSource="{Binding FavoriteItems}"
                 ItemTemplate="{StaticResource BrowserListItemTemplate}"
                 MouseDoubleClick="FavoritesListBox_OnMouseDoubleClick"
                 MouseRightButtonUp="FavoritesListBox_OnRightClick"
                 KeyDown="ListBox_OnKeyDown"
                 BorderThickness="0">
          <ListBox.Style>
            <Style TargetType="ListBox" BasedOn="{StaticResource ModernListBox}">
              <Setter Property="Background" Value="Transparent"/>
              <!-- 保留 Visibility=Visible 让 Opacity 动画起效（Collapsed 会跳过渲染管线）；
                   用 IsHitTestVisible=False 屏蔽非激活 Tab 的鼠标事件 -->
              <Setter Property="Visibility" Value="Visible"/>
              <Setter Property="Opacity" Value="0"/>
              <Setter Property="IsHitTestVisible" Value="False"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavoritesTab}" Value="True">
                  <Setter Property="IsHitTestVisible" Value="True"/>
                  <DataTrigger.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" EasingFunction="{StaticResource EaseOutCubic}"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </DataTrigger.EnterActions>
                  <DataTrigger.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </DataTrigger.ExitActions>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
          <ListBox.ItemContainerStyle>
            <StaticResource ResourceKey="ModernListBoxItem"/>
          </ListBox.ItemContainerStyle>
        </ListBox>

        <ListBox x:Name="HistoryListBox"
                 ItemsSource="{Binding HistoryItems}"
                 ItemTemplate="{StaticResource BrowserListItemTemplate}"
                 MouseDoubleClick="HistoryListBox_OnMouseDoubleClick"
                 MouseRightButtonUp="HistoryListBox_OnRightClick"
                 KeyDown="ListBox_OnKeyDown"
                 BorderThickness="0">
          <ListBox.Style>
            <Style TargetType="ListBox" BasedOn="{StaticResource ModernListBox}">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Visibility" Value="Visible"/>
              <Setter Property="Opacity" Value="1"/>
              <Setter Property="IsHitTestVisible" Value="True"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavoritesTab}" Value="True">
                  <Setter Property="IsHitTestVisible" Value="False"/>
                  <DataTrigger.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </DataTrigger.EnterActions>
                  <DataTrigger.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" EasingFunction="{StaticResource EaseOutCubic}"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </DataTrigger.ExitActions>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
          <ListBox.ItemContainerStyle>
            <StaticResource ResourceKey="ModernListBoxItem"/>
          </ListBox.ItemContainerStyle>
        </ListBox>

        <TextBlock Text="{Binding FavoritesEmptyText}"
                   FontSize="13" Foreground="{DynamicResource TextTertiary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" TextWrapping="Wrap" LineHeight="20"
                   MaxWidth="280" IsHitTestVisible="False">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsFavoritesTab}" Value="True"/>
                    <Condition Binding="{Binding FavoriteItems.Count}" Value="0"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <TextBlock Text="{Binding HistoryEmptyText}"
                   FontSize="13" Foreground="{DynamicResource TextTertiary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" TextWrapping="Wrap" LineHeight="20"
                   MaxWidth="280" IsHitTestVisible="False">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsFavoritesTab}" Value="False"/>
                    <Condition Binding="{Binding HistoryItems.Count}" Value="0"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </Grid>

    <Border Grid.RowSpan="5"
            Tag="{Binding IsToastVisible}"
            Visibility="{Binding ToastVisibility}"
            Background="{DynamicResource BackgroundTertiary}"
            CornerRadius="8"
            Padding="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            MaxWidth="360"
            Margin="0,0,8,8">
      <Border.Style>
        <Style TargetType="Border" BasedOn="{StaticResource ToastBorderStyle}">
          <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding ToastSeverity}" Value="Success">
              <Setter Property="BorderBrush" Value="{DynamicResource AccentSuccess}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ToastSeverity}" Value="Warning">
              <Setter Property="BorderBrush" Value="{DynamicResource AccentWarning}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ToastSeverity}" Value="Error">
              <Setter Property="BorderBrush" Value="{DynamicResource AccentDanger}"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <Grid>
        <Grid.ColumnDefinitions>
          <!-- 左侧 4px 严重度色条：与 BorderBrush 联动，让 Toast 类型一眼可辨 -->
          <ColumnDefinition Width="4"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" CornerRadius="2,0,0,2" Margin="0,6">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ToastSeverity}" Value="Success">
                  <Setter Property="Background" Value="{DynamicResource AccentSuccess}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ToastSeverity}" Value="Warning">
                  <Setter Property="Background" Value="{DynamicResource AccentWarning}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ToastSeverity}" Value="Error">
                  <Setter Property="Background" Value="{DynamicResource AccentDanger}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
        </Border>
        <TextBlock Grid.Column="1" FontSize="14"
                   VerticalAlignment="Center" Margin="12,12,8,12">
          <TextBlock.Style>
            <Style TargetType="TextBlock" BasedOn="{StaticResource Mdl2IconText}">
              <Setter Property="Text" Value="&#xE946;"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ToastSeverity}" Value="Success">
                  <Setter Property="Text" Value="&#xE73E;"/>
                  <Setter Property="Foreground" Value="{DynamicResource AccentSuccess}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ToastSeverity}" Value="Warning">
                  <Setter Property="Text" Value="&#xE7BA;"/>
                  <Setter Property="Foreground" Value="{DynamicResource AccentWarning}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ToastSeverity}" Value="Error">
                  <Setter Property="Text" Value="&#xE783;"/>
                  <Setter Property="Foreground" Value="{DynamicResource AccentDanger}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <TextBlock Grid.Column="2" Text="{Binding ToastMessage}" Foreground="{DynamicResource TextPrimary}"
                   TextWrapping="Wrap" FontSize="12" VerticalAlignment="Center" Margin="0,12,14,12"/>
      </Grid>
    </Border>
  </Grid>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- GitHub-inspired dark palette -->
  <Color x:Key="ColorBackgroundPrimary">#0F1419</Color>
  <Color x:Key="ColorBackgroundSecondary">#1C2128</Color>
  <Color x:Key="ColorBackgroundTertiary">#2D333B</Color>
  <Color x:Key="ColorBackgroundHover">#373E47</Color>
  <Color x:Key="ColorBorder">#444C56</Color>
  <Color x:Key="ColorBorderStrong">#8B949E</Color>
  <Color x:Key="ColorAccentPrimary">#58A6FF</Color>
  <Color x:Key="ColorAccentSuccess">#3FB950</Color>
  <Color x:Key="ColorAccentSuccessDark">#238636</Color>
  <Color x:Key="ColorAccentSuccessBorder">#2EA043</Color>
  <Color x:Key="ColorAccentDanger">#F85149</Color>
  <Color x:Key="ColorAccentWarning">#FFC83D</Color>
  <Color x:Key="ColorCloseButtonPressed">#B62324</Color>
  <!-- 模式强调色：浏览=蓝，浮窗=橙（分段高亮 / 主窗描边闪） -->
  <Color x:Key="ColorModeBrowsingAccent">#58A6FF</Color>
  <Color x:Key="ColorModeFloatingAccent">#F0A020</Color>
  <Color x:Key="ColorModeFloatingAccentSoft">#33F0A020</Color>
  <Color x:Key="ColorListDivider">#21262D</Color>
  <Color x:Key="ColorTextPrimary">#E6EDF3</Color>
  <Color x:Key="ColorTextSecondary">#8B949E</Color>
  <Color x:Key="ColorTextTertiary">#6E7681</Color>
  <Color x:Key="ColorSelection">#264F78</Color>

  <SolidColorBrush x:Key="BackgroundPrimary" Color="{StaticResource ColorBackgroundPrimary}"/>
  <SolidColorBrush x:Key="BackgroundSecondary" Color="{StaticResource ColorBackgroundSecondary}"/>
  <SolidColorBrush x:Key="BackgroundTertiary" Color="{StaticResource ColorBackgroundTertiary}"/>
  <SolidColorBrush x:Key="BackgroundHover" Color="{StaticResource ColorBackgroundHover}"/>
  <SolidColorBrush x:Key="BorderColor" Color="{StaticResource ColorBorder}"/>
  <SolidColorBrush x:Key="BorderColorStrong" Color="{StaticResource ColorBorderStrong}"/>
  <SolidColorBrush x:Key="AccentPrimary" Color="{StaticResource ColorAccentPrimary}"/>
  <SolidColorBrush x:Key="AccentSuccess" Color="{StaticResource ColorAccentSuccess}"/>
  <SolidColorBrush x:Key="AccentSuccessDark" Color="{StaticResource ColorAccentSuccessDark}"/>
  <SolidColorBrush x:Key="AccentSuccessBorder" Color="{StaticResource ColorAccentSuccessBorder}"/>
  <SolidColorBrush x:Key="AccentDanger" Color="{StaticResource ColorAccentDanger}"/>
  <SolidColorBrush x:Key="AccentWarning" Color="{StaticResource ColorAccentWarning}"/>
  <SolidColorBrush x:Key="CloseButtonPressed" Color="{StaticResource ColorCloseButtonPressed}"/>
  <SolidColorBrush x:Key="ModeBrowsingAccent" Color="{StaticResource ColorModeBrowsingAccent}"/>
  <SolidColorBrush x:Key="ModeFloatingAccent" Color="{StaticResource ColorModeFloatingAccent}"/>
  <SolidColorBrush x:Key="ModeFloatingAccentSoft" Color="{StaticResource ColorModeFloatingAccentSoft}"/>
  <SolidColorBrush x:Key="ListDivider" Color="{StaticResource ColorListDivider}"/>
  <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource ColorTextPrimary}"/>
  <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource ColorTextSecondary}"/>
  <SolidColorBrush x:Key="TextTertiary" Color="{StaticResource ColorTextTertiary}"/>
  <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource ColorSelection}"/>
</ResourceDictionary>
